<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{title}} — Rahvusarhiivi disainisüsteem</title>

    <link rel="stylesheet" href="{{ relative }}{{ '/assets/css/style.css' | url }}">
    <link rel="stylesheet" href="{{ relative }}{{ '/assets/css/themes/prism-ghcolors.css'}}" />

    {# https://www.npmjs.com/package/eleventy-plugin-code-clipboard #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@mdi/font@6.5.95/css/materialdesignicons.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Primer/19.1.1/tooltips.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

    {# Fonts from Google Fonts CDN #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@600&family=Roboto:ital,wght@0,400;0,500;0,700;1,400;1,700&display=swap" rel="stylesheet">

    {# Syntax highlighting styles #}
    <link href="https://unpkg.com/prism-themes/themes/prism-one-light.css" rel="stylesheet">

    <style>
      .tooltipped::before {
        color: #fcf !important;
        border-bottom-color: #ffccff !important;
      }

      .tooltipped::after {
        background-color: #fcf !important;
        color: #303 !important;
      }
    </style>

    {# Lightweight AlpineJS for dynamic elements and attributes #}
    {# AlpineJS Persist (localStorage) plugin before AlpineJS Core  #}
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/persist@3.12.3/dist/cdn.min.js"></script>
    {# Alpine Core #}
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.12.3/dist/cdn.min.js"></script>

    {# Copy icon to clipboard script #}
    <script>
      function copy(el) {
        navigator.clipboard.writeText(el.innerHTML);
        el.nextElementSibling.textContent="Kopeeritud"
        el.nextElementSibling.classList.remove("hidden");
        setTimeout(function(){
            el.nextElementSibling.classList.add("hidden");
            el.nextElementSibling.textContent="Kopeeri"
        }, 2000);
      }
    </script>

  </head>
  <body class="bg-gray-50">
    {% include "_header.njk" %}

    <div class="grid lg:grid-cols-12 gap-2 m-2">
      {% include "_sidebar.njk" %}
      <main class="lg:col-span-9 p-6 bg-white rounded-sm shadow">

        {% if formatContent === false %}
          <article>
            {{content | safe}}
          </article>
        {% else %}
          <article class="prose prose-lg max-w-5xl">
            {{content | safe}}
          </article>
        {% endif %}

      </main>
    </div>
    {% initClipboardJS %}

  </body>
</html>